# 复制为项目根目录 `.env` 后再填写真实值。
# 应用启动时会自动读取该文件，适用于 IDE 直接跑 main 和 `mvn spring-boot:run`。

# Spring profile，通常本地使用 dev
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai

# 服务监听端口
SERVER_PORT=8081

# MySQL，库名建议保持为 LetsLearn
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/LetsLearn?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka，topic 会在应用启动时自动创建，无需再手工执行 kafka-topics.sh
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SPRING_KAFKA_TOPIC_PARTITIONS=1
SPRING_KAFKA_TOPIC_REPLICATION_FACTOR=1

# MinIO，对象存储用于文件上传与解析链路
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uploads

# Elasticsearch。
# 本地自签名证书可用 https + trust-all=true；
# 生产环境务必改为 trust-all=false，并确保 JVM 信任该证书链。
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=https
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me
ELASTICSEARCH_INSECURE_TRUST_ALL_CERTIFICATES=true

# JWT_SECRET_KEY 必须是 Base64 字符串，可用 `openssl rand -base64 32` 生成
JWT_SECRET_KEY=XeJw0yUoFDJWSNbWYFVEIXGfO8XgHrQLrIkKci5J9eA=

# 首次启动创建管理员时临时打开，创建成功后应改回 false
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
ADMIN_BOOTSTRAP_PRIMARY_ORG=default
ADMIN_BOOTSTRAP_ORG_TAGS=default,admin

# 注册模式：OPEN / INVITE_ONLY / CLOSED
APP_AUTH_REGISTRATION_MODE=INVITE_ONLY
APP_AUTH_INVITE_REQUIRED=true

# 前端来源白名单，多个域名用逗号分隔
SECURITY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# LLM 与 Embedding 提供方
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_API_KEY=

# 日志等级，排障时可临时改为 DEBUG
LOG_LEVEL_APP=INFO

# 前端部署
DEPLOY_SERVER_HOST=
DEPLOY_SERVER_USER=root
DEPLOY_SERVER_KEY=/absolute/path/to/paicoding.pem
DEPLOY_TARGET_DIR=/home/www/LetsLearn-Front
DEPLOY_HEALTHCHECK_URL=https://smart.paicoding.com
DEPLOY_HEALTHCHECK_TIMEOUT=15

# 微信支付相关配置
WX_PAY_ENABLE=false
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY=
WX_PAY_MERCHANT_SERIAL_NUMBER=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=https://smart.paicoding.com/api/v1/recharge/pay-callback
WX_PAY_REFUND_NOTIFY_URL=https://smart.paicoding.com/api/v1/recharge/refund-callback

# LiteParse PDF 解析
# FILE_PARSING_LITEPARSE_COMMAND 不是必填项；如果后端进程能直接执行
# `lit --help`，默认值 `lit` 就够用。
# 生产环境建议配置为 `which lit` 查到的绝对路径，避免 systemd/Docker/IDE
# 的 PATH 和当前 shell 不一致。
FILE_PARSING_LITEPARSE_COMMAND=lit

# OCR 需要先安装并验证 Tesseract 语言数据。
# 普通带文本层的 PDF 可先关闭 OCR，避免缺 tessdata 时解析失败。
FILE_PARSING_LITEPARSE_OCR_ENABLED=false
FILE_PARSING_LITEPARSE_OCR_LANGUAGE=chi_sim+eng

# Tesseract 语言包目录，目录下应包含 eng.traineddata 和 chi_sim.traineddata。
# LetsLearn 会把该值作为 TESSDATA_PREFIX 环境变量传给 LiteParse 子进程。
# macOS 示例：/Users/yourname/Library/Application Support/tesseract-rs/tessdata
# Linux 示例：/usr/local/share/tessdata
# Windows 示例：C:/Users/yourname/AppData/Roaming/tesseract-rs/tessdata
FILE_PARSING_LITEPARSE_TESSDATA_PATH=
